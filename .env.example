# --- Bright Data (required) ---
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker
BRIGHTDATA_SERP_ZONE=serp_api
BRIGHTDATA_LINKEDIN_JOBS_DATASET=gd_lpfll7v5hcqtkxl6l
# Browser API (Scraping Browser) CDP endpoint - enables JS-rendered pricing pages.
# Format: wss://brd-customer-<id>-zone-<zone>:<password>@brd.superproxy.io:9222
BRIGHTDATA_BROWSER_CDP=

# --- LLM (optional; falls back to deterministic synthesis if unset) ---
# LLM_PROVIDER: azure | aimlapi | featherless
LLM_PROVIDER=azure

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# AI/ML API (partner - OpenAI-compatible)
AIMLAPI_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=gpt-4o

# Featherless AI (partner - open-source model inference, OpenAI-compatible)
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# --- Speechmatics (optional, partner - voice query of an account) ---
SPEECHMATICS_API_KEY=

# --- TriggerWare (optional, partner - fire an automation on a signal/action) ---
TRIGGERWARE_API_KEY=
TRIGGERWARE_WEBHOOK_URL=

# --- Cognee (optional - cross-run memory / change detection backend) ---
# When set AND the key authenticates, run snapshots mirror to the Cognee knowledge
# graph; otherwise change detection runs on the local store (.recon_memory.json).
COGNEE_API_KEY=
COGNEE_BASE_URL=
COGNEE_TENANT_ID=

# --- HubSpot (live agentic CRM push; optional) ---
HUBSPOT_ACCESS_TOKEN=
# Live writes to the configured HubSpot only when explicitly enabled (keeps a public
# demo from writing to your production CRM). Leave UNSET on any deployed/public app.
RECON_ENABLE_PUSH=
